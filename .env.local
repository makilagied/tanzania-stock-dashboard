# Copy to `.env.local` and fill in values. Never commit real secrets.

# -----------------------------------------------------------------------------
# Supabase — durable last-good API snapshots (required on Vercel for cross-instance cache)
# Run `supabase/migrations/001_stale_cache.sql` in the Supabase SQL editor first.
#
# One variable per line. Do not merge names (wrong: NEXT_PUBLIC_SUPABASE_URLSUPABASE_ANON_KEY).
# -----------------------------------------------------------------------------
SUPABASE_URL=
# Same project URL as above (needed if you only set the public one):
# Browser / client SDK — prefer publishable key (Supabase dashboard) or legacy anon JWT:
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (stale snapshot upserts). Never NEXT_PUBLIC_* or commit to git.
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SUPABASE_URL=https://qnfyekbeotgiappzelyq.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_LgMpHL1lVGN4KXoGyOku_A_3i3oUp6H

# -----------------------------------------------------------------------------
# SQLite — local dev when Supabase vars above are empty
# Not used on Vercel unless you opt in (not recommended for durability).
# -----------------------------------------------------------------------------
# SQLITE_PATH=./data/cache.db
# SQLITE_DISABLED=0
# SQLITE_ON_VERCEL=0

# -----------------------------------------------------------------------------
# Market data
# -----------------------------------------------------------------------------
# HISTORICAL_DATA_API_BASE=
# MARKET_UPSTREAM_TIMEOUT_MS=20000

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# API route guard (middleware) — enforced in production; dev skips unless strict
# -----------------------------------------------------------------------------
# Comma-separated site origins (scheme + host, no trailing slash) for cross-origin browser calls.
# ALLOWED_ORIGINS=https://example.com,https://www.example.com
# Comma-separated allowed Host header values (no port unless needed).
# ALLOWED_API_HOSTS=example.com,www.example.com
# Cron/scripts: Authorization: Bearer <this value>
# API_ROUTE_BYPASS_SECRET=
# Set to "true" to enforce the same API guard in development.
# API_GUARD_STRICT_IN_DEV=false
